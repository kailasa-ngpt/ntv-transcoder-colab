# Copy to .env (locally) OR add these as Colab Secrets (recommended). Never commit real values.

# ==== Cloudflare R2 (REQUIRED for transcode + upload) ====
CLOUDFLARE_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
BUCKET_NAME=ntv-ott
CLOUDFLARE_DOMAIN=https://your_r2_account_id.r2.cloudflarestorage.com

# ==== Public CDN base for playback URLs (optional) ====
# Where the bucket is served publicly, e.g. https://ntv-cms.nithyananda.ai
CDN_BASE_URL=

# ==== NTV / Payload CMS (optional — only needed to push details to NTV) ====
CMS_URL=https://ntv-dev-cms.koogle.sk
CMS_API_KEY=

# ==== Optional: enrich metadata from YouTube (batch pipeline only) ====
YOUTUBE_API_KEY=
NVIDIA_API_KEY=

# ==== HLS tuning (optional) ====
HLS_SEGMENT_TIME=6
AUDIO_BITRATE=128k
